# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT Authentication
JWT_SECRET=generate-a-random-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Plaid (https://dashboard.plaid.com)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Encryption key for Plaid access tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=generate-a-fernet-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
